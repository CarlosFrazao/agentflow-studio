# AgentFlow Studio — variáveis de ambiente (copiar para .env)

# App
ENVIRONMENT=development
DEBUG=true

# Database (SQLite local do MVP)
DATABASE_URL=sqlite+aiosqlite:///./data/agentflow.db

# CORS (frontend React em dev) — pydantic-settings espera JSON para listas
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# --- SRA (Smart Research Agent) — MCP SSE remoto ---
SRA_MCP_URL=http://sra-app:3458/mcp/sse
SRA_API_KEY=
SRA_CALL_TIMEOUT_S=90

# --- Firecrawl (self-hosted) — MCP SSE com fallback REST ---
FIRECRAWL_MCP_URL=http://firecrawl-api-new:3002/mcp/sse
FIRECRAWL_REST_URL=http://firecrawl-api-new:3002
FIRECRAWL_API_KEY=local_bypass
FIRECRAWL_CALL_TIMEOUT_S=30

# --- GitHub API (REST direto) ---
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_CALL_TIMEOUT_S=30

# --- LLM Multi-provider (fallback automático) ---
# Ordem de tentativa: OpenRouter (free) -> Groq (free) -> Gemini (free) -> Ollama (local)
# Defina as chaves dos provedores que quiser usar. Pelo menos um deve ter chave válida.
LLM_PROVIDER=openrouter

# OpenRouter (free tier) - https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Groq (free tier) - https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free tier) - https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local, sem chave) - https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Circuit breaker (degradação graciosa) ---
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RESET_S=60

# --- Demo mode (v1.2) ---
# Quando true, POST /cards/{id}/run retorna payload mock (sem chamar LLM real),
# evitando custo/erros em demonstrações locais sem chave de API.
# OPCIONAL — deixe vazio/false para usar os agentes reais.
DEMO_MODE=false

# --- Autenticação JWT (v1.2 — FEAT-001) ---
# OBRIGATÓRIO em produção (ENVIRONMENT=production). Se ausente em produção,
# o app RECUSA subir (fail-closed) — evita JWT forjável com secret conhecido.
# Em dev (ENVIRONMENT=development), se ausente, um secret efêmero é gerado
# por processo (NÃO persistido) — apenas para conveniência local.
# Gere um valor forte, ex: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=12
